# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ────────────────────────────────────────────────────────────────
# SQLite for local development (zero config):
DATABASE_URL=sqlite:///./regavim.db

# PostgreSQL for production (uncomment and fill in):
# DATABASE_URL=postgresql://user:password@localhost:5432/regavim

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Email (complaint submission) ─────────────────────────────────────────────
# PREFERRED: Resend HTTPS API. Required on hosts that block outbound SMTP (Render).
# When RESEND_API_KEY is set it is used automatically. RESEND_FROM must be a
# Resend-verified sender; the sandbox onboarding@resend.dev works for testing and
# only delivers to your own Resend account email until a domain is verified.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# SMTP fallback — used only when RESEND_API_KEY is blank (local/dev; not on Render).
# For Gmail use an App Password as SMTP_PASSWORD.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SENDER_EMAIL=
SMTP_USE_TLS=true

# Recipient email per authority. Blank = authority shown disabled in the UI.
# Supply real addresses before filing real complaints; use a test inbox until then.
COMPLAINT_EMAIL_POLICE=
COMPLAINT_EMAIL_ILA=
COMPLAINT_EMAIL_ENV_MINISTRY=
COMPLAINT_EMAIL_LOCAL_PLANNING=
COMPLAINT_EMAIL_CIVIL_ADMIN=
