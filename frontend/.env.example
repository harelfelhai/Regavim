# URL of the FastAPI backend. No trailing slash.
#
# Development / GitHub Codespaces:
#   Leave this UNSET (or empty). Vite's dev proxy forwards /api/* requests to
#   http://localhost:8000 inside the container — no CORS, no env var needed.
#
# Production:
#   Set this to the deployed API root, e.g.:
#   VITE_API_BASE_URL=https://api.regavim.org
VITE_API_BASE_URL=
